{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ios-base",
      "hidden": true,
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "16.4",
        "OPENMW_IOS_BOOTSTRAP": "ON",
        "OPENMW_IOS_ENABLE_CODE_SIGNING": "OFF"
      }
    },
    {
      "name": "ios-product-base",
      "hidden": true,
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "16.4",
        "OPENMW_IOS_BOOTSTRAP": "OFF",
        "OPENMW_IOS_ENABLE_CODE_SIGNING": "OFF",
        "USE_LUAJIT": "OFF"
      }
    },
    {
      "name": "ios-device",
      "displayName": "iOS 16.4 device (arm64)",
      "description": "Hermetic OpenMW iOS bootstrap for iphoneos/arm64.",
      "inherits": "ios-base",
      "binaryDir": "${sourceDir}/build/ios-device",
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "iphoneos"
      }
    },
    {
      "name": "ios-simulator",
      "displayName": "iOS 16.4 simulator (arm64)",
      "description": "Hermetic OpenMW iOS bootstrap for iphonesimulator/arm64.",
      "inherits": "ios-base",
      "binaryDir": "${sourceDir}/build/ios-simulator",
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "iphonesimulator"
      }
    },
    {
      "name": "ios-product-device",
      "displayName": "OpenMW iOS 16.4 product — device (arm64)",
      "description": "Configure the pruned OpenMW iOS product for iphoneos/arm64. Requires the phase 2 dependency prefix.",
      "inherits": "ios-product-base",
      "binaryDir": "${sourceDir}/build/ios-product-device",
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "OPENMW_IOS_DEPS_ROOT": "${sourceDir}/build/ios-deps/iphoneos/vcpkg_installed/arm64-ios-openmw"
      }
    },
    {
      "name": "ios-product-simulator",
      "displayName": "OpenMW iOS 16.4 product — simulator (arm64)",
      "description": "Configure the pruned OpenMW iOS product for iphonesimulator/arm64. Requires the phase 2 dependency prefix.",
      "inherits": "ios-product-base",
      "binaryDir": "${sourceDir}/build/ios-product-simulator",
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "OPENMW_IOS_DEPS_ROOT": "${sourceDir}/build/ios-deps/iphonesimulator/vcpkg_installed/arm64-ios-simulator-openmw"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ios-device-debug",
      "displayName": "Build iOS device bootstrap (Debug)",
      "configurePreset": "ios-device",
      "configuration": "Debug",
      "targets": [
        "openmw-ios-bootstrap"
      ],
      "jobs": 4
    },
    {
      "name": "ios-simulator-debug",
      "displayName": "Build iOS simulator bootstrap (Debug)",
      "configurePreset": "ios-simulator",
      "configuration": "Debug",
      "targets": [
        "openmw-ios-bootstrap"
      ],
      "jobs": 4
    },
    {
      "name": "ios-product-device-relwithdebinfo",
      "displayName": "Build OpenMW iOS product — device (RelWithDebInfo)",
      "configurePreset": "ios-product-device",
      "configuration": "RelWithDebInfo",
      "jobs": 4
    },
    {
      "name": "ios-product-simulator-debug",
      "displayName": "Build OpenMW iOS product — simulator (Debug)",
      "configurePreset": "ios-product-simulator",
      "configuration": "Debug",
      "jobs": 4
    }
  ]
}
